<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.box.ConectActivity">

    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/open_sans_bold"
        android:textColor="@color/darkCyanBlue"
        android:textSize="25sp"
        android:background="@drawable/auth_shape"
        android:padding="15dp"
        android:text="@string/conectMessage"
        android:gravity="center"
        android:layout_margin="15dp"
        android:layout_alignParentTop="true"/>

    <TextView
        android:id="@+id/code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/open_sans_regular"
        android:textColor="@color/cyanBold"
        android:background="@drawable/shape_cyan"
        android:textStyle="bold"
        android:layout_below="@+id/title"
        android:textSize="18sp"
        android:layout_centerHorizontal="true"
        android:layout_margin="15dp"
        android:padding="20dp"
        android:text="@string/digiteCode"/>

    <EditText
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp"
        android:layout_marginHorizontal="20dp"
        android:id="@+id/editIp"
        android:gravity="center"
        android:fontFamily="@font/open_sans_italic"
        android:textStyle="bold"
        android:textColor="@color/blackBlue"
        android:background="@drawable/enter_info_shape"
        android:hint="@string/digiteCode_hint"
        android:layout_below="@+id/code"/>

    <androidx.appcompat.widget.AppCompatButton
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/but_log_bcg"
        android:text="@string/buttonSendBox"
        android:textAllCaps="false"
        android:textSize="20sp"
        android:textColor="@color/white"
        android:fontFamily="@font/open_sans_bold"
        android:layout_marginHorizontal="20dp"
        android:layout_marginVertical="20dp"
        android:layout_below="@id/editIp"
        android:id="@+id/butSend"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/butReturn"
        android:src="@drawable/outline_arrow_back_24"
        android:backgroundTint="@color/cyanBold"
        android:layout_alignParentBottom="true"
        android:layout_margin="20dp"/>

</RelativeLayout>