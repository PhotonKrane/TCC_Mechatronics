<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    tools:context=".ui.splashscreen.SplashScreenActivity"
    android:background="@color/purple_gray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:id="@+id/title"
        android:layout_marginVertical="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/open_sans_bold"
            android:gravity="center"
            android:text="@string/medicabox"
            android:textColor="@color/cyanBold"
            android:layout_centerInParent="true"
            android:textSize="60sp"
            android:textStyle="bold"
            android:id="@+id/medicName" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sua_caixa_organizadora"
            android:gravity="center"
            android:layout_marginTop="15dp"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="@font/open_sans_regular"
            android:textColor="@color/cyanBold"
            android:id="@+id/subTitle"/>
    </LinearLayout>

    <ImageView
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:src="@drawable/dark_medic_logo"
        android:id="@+id/logo"
        android:layout_marginTop="70dp"
        android:layout_gravity="center"/>

</LinearLayout>