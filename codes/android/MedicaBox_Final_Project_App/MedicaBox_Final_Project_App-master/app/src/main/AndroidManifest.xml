<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Permissões básicas -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.WAKE_LOCK" /> <!-- Para bypassar Não Perturbe (opcional mas importante) -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" /> <!-- Para tocar em volume máximo -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" /> <!-- Alarmes exatos (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MedicaBox"
        tools:targetApi="31">
        <activity
            android:name=".notifications.ui.SeeNotifyActivity"
            android:exported="false" />
        <activity
            android:name=".ui.notify.NotifyInfoActivity"
            android:exported="false" />
        <activity
            android:name=".ui.box.BoxOrNotifyActivity"
            android:exported="false" />

        <receiver
            android:name=".notifications.MyReceiver"
            android:exported="true" />

        <activity
            android:name=".ui.box.PacSelectActivity"
            android:exported="false" />
        <activity
            android:name=".ui.nurse.RemoveNurseActivity"
            android:exported="false" />
        <activity
            android:name=".ui.account.NursingActivity"
            android:exported="false" />
        <activity
            android:name=".ui.box.ConectActivity"
            android:exported="false" />
        <activity
            android:name=".ui.box.TimePicker"
            android:exported="false" />
        <activity
            android:name=".ui.box.BoxInfoActivity"
            android:exported="false" />
        <activity
            android:name=".ui.box.TimeConfigActivity"
            android:exported="false" />
        <activity
            android:name=".ui.account.UserInfoActivity"
            android:exported="false" />
        <activity
            android:name=".ui.box.BoxAddActivity"
            android:exported="false" />
        <activity
            android:name=".ui.box.MedicDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.login.RecoverPassActivity"
            android:exported="false" />
        <activity
            android:name=".ui.login.AuthActivity"
            android:exported="false" />
        <activity
            android:name=".ui.splashscreen.SplashScreenActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.login.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".ui.MainActivity"
            android:exported="true" />
    </application>

</manifest>